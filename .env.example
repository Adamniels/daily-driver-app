# Copy to .env and adjust. .env is gitignored.

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://habit:habit@localhost:5432/habitquest
TEST_DATABASE_URL=postgres://habit:habit@localhost:5432/habitquest_test

# API
API_PORT=3001
# Generate a real one for production: openssl rand -base64 32
JWT_SECRET=dev-secret-change-me

# Expo app → API base url
EXPO_PUBLIC_API_URL=http://localhost:3001
