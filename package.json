{
  "name": "habit-quest",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
